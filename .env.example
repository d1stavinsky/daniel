# Core application
DATABASE_URL=
BETTER_AUTH_SECRET=
# Public HTTPS origin, for example https://ensura.co.il
# On the VPS this must match the URL users open (e.g. https://ensura.co.il)
BETTER_AUTH_URL=
NEXT_PUBLIC_APP_URL=
# Optional comma-separated extra origins trusted by Better Auth (CSRF)
# AUTH_TRUSTED_ORIGINS=https://ensura.co.il,https://www.ensura.co.il
AUTH_TRUSTED_ORIGINS=
BLOB_READ_WRITE_TOKEN=

# Resend outbound and inbound email
RESEND_API_KEY=
# Verified sender format: ENSURA <claims@your-domain.com>
RESEND_FROM=
# Inbox for public join/contact leads (defaults to RESEND_FROM)
LEADS_INBOX_EMAIL=
RESEND_WEBHOOK_SECRET=
# Exact address that receives claim emails
RESEND_INBOUND_ADDRESS=

# Twilio WhatsApp Intake
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Full public webhook URL ending in /api/webhook/whatsapp-intake
WHATSAPP_WEBHOOK_PUBLIC_URL=
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_INTAKE_DEFAULT_PARTNER_ID=
# Optional dedicated signing secret; falls back to BETTER_AUTH_SECRET
WHATSAPP_INTAKE_LINK_SECRET=
# Optional; defaults to NEXT_PUBLIC_APP_URL
CLIENT_INTAKE_PUBLIC_URL=
# Optional: true enables raw parser diagnostics in production (contains customer PII)
WHATSAPP_INTAKE_DEBUG=

# Scheduled operational scan (invoke /api/cron/scan-stuck from cron)
CRON_SECRET=

# Optional document extraction
OPENAI_API_KEY=
OPENAI_IDP_MODEL=gpt-4o-mini

# Public client communication details
AXIS_CONTACT_PHONE=
AXIS_CONTACT_ADDRESS=
